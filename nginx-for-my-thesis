#nginx setup with backend user and admin domain
#!/bin/bash

sudo -i <<'EOF'

# Update package list
apt update

# Install nginx
apt install -y nginx

# Enable firewall and allow ssh & nginx
ufw --force enable
ufw allow ssh
ufw allow 'Nginx Full'

# Check firewall status
ufw status

# Restart nginx
systemctl restart nginx

# Create nginx config for user backend and backend
cat <<'EOT' > /etc/nginx/sites-available/parkingreservation
# FRONTEND (USER)
server {
    listen 80;
    listen [::]:80;

    server_name parkingreservation.online;

    location / {
        proxy_pass http://localhost:3000;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_cache_bypass $http_upgrade;
    }
}

# ADMIN PORTAL
server {
    listen 80;
    listen [::]:80;

    server_name portal.parkingreservation.online;

    location / {
        proxy_pass http://localhost:3001; 
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_cache_bypass $http_upgrade;
    }
}

# BACKEND API
server {
    listen 80;
    listen [::]:80;

    server_name api.parkingreservation.online;

    location / {
        proxy_pass http://localhost:4000;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_cache_bypass $http_upgrade;
    }
}


EOT

# Enable the site
ln -sf /etc/nginx/sites-available/parkingreservation /etc/nginx/sites-enabled/parkingreservation

# Test the configuration
nginx -t

# Restart nginx configuration
systemctl restart nginx

# Install certbot and the nginx plugin
apt install -y certbot python3-certbot-nginx

EOF
